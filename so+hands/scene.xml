<mujoco model="so_arm100 scene">
  <include file="so_arm100.xml"/>

  <statistic center="0.1 -0.01 0.05" extent="0.5"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="45" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <asset>
    <material name="block_red"  rgba="0.85 0.15 0.15 1"/>
    <material name="table_wood" rgba="0.72 0.52 0.30 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!--
      Block sits on the floor.  The floor plane already provides collision.
      Block at y=-0.29 (arm workspace), center z=0.025 (sitting on floor).
      Arm init is upright (away from this area) so no spawn collision.
    -->
    <body name="block" pos="0.0 -0.29 0.025">
      <freejoint name="block_joint"/>
      <geom name="block_geom" type="box" size="0.025 0.025 0.025"
            material="block_red" mass="0.05"
            friction="2.0 0.1 0.01" condim="6"/>
    </body>
  </worldbody>
</mujoco>
